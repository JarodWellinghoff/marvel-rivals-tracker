{
  "manifest_version": "1",
  "type": "WebApp",
  "permissions": ["Extensions", "Hotkeys", "GameInfo", "FileSystem"],
  "meta": {
    "name": "Marvel Rivals Companion",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.220.0.1",
    "author": "Overwolf",
    "icon": "assets/icon.png",
    "icon_gray": "assets/icon_gray.png",
    "launcher_icon": "assets/desktop_icon.ico",
    "description": "Real-time game event tracking for Marvel Rivals"
  },
  "data": {
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [24890]
    },
    "start_window": "index",
    "windows": {
      "index": {
        "open_dev_tools": true,
        "file": "windows/index/page.html",
        "is_background_page": true,
        "native_window": true,
        "desktop_only": true,
        "dev_tools_window_style": false
      },
      "in-game": {
        "open_dev_tools": true,
        "file": "windows/in-game/page.html",
        "focus_game_takeover": "ReleaseOnHidden",
        "focus_game_takeover_release_hotkey": "rivals_showhide",
        "is_background_page": true,
        "native_window": true,
        "desktop_only": true,
        "dev_tools_window_style": false
      }
    },
    "game_events": [24890],
    "hotkeys": {
      "rivals_showhide": {
        "title": "Toggle Marvel Rivals Overlay",
        "action-type": "custom",
        "default": "Ctrl+G",
        "game_ids": [24890]
      }
    },
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [24890]
        },
        "start_minimized": false
      }
    ],
    "extra-objects": {
      "simple-io-plugin": {
        "file": "plugins/simple-io-plugin.dll",
        "class": "overwolf.plugins.simpleio.SimpleIOPlugin"
      }
    },
    "developer": {
      "enable_auto_refresh": true,
      "reload_delay": 1000,
      "filter": "*.*"
    }
  }
}

